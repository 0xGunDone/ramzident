[Unit]
Description=Ramzident Next.js application
After=network.target

[Service]
Type=simple
User=ramzident
Group=ramzident
WorkingDirectory=/var/www/ramzident
Environment=NODE_ENV=production
EnvironmentFile=/var/www/ramzident/.env
ExecStart=/usr/bin/npm run start -- --hostname 127.0.0.1 --port 3000
Restart=always
RestartSec=5
TimeoutStartSec=60

# Basic hardening
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ProtectHome=true
# Keep uploads and SQLite writable even when the app lives in a nested folder
# such as /var/www/product/ramzident.
ReadWritePaths=/var/www

[Install]
WantedBy=multi-user.target
