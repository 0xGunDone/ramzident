DATABASE_URL="file:./dev.db"

NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-a-random-secret"
ADMIN_EMAIL="admin@ramzident.ru"
ADMIN_PASSWORD="replace-with-a-secure-password"

# All other settings (site name, phone, address, work hours,
# map coordinates, OpenRouter API key, etc.) are managed through
# the admin panel at /admin/settings and stored in the database.
#
# On first run, execute `npm run db:seed` to populate defaults.
# The seed reads from env vars below if present, otherwise uses
# hardcoded defaults. After seeding, all values are editable
# from the admin UI.
#
# Optional env overrides (used as fallbacks if DB value is empty):
# SITE_URL="https://ramzident.ru"
# SITE_NAME="Рамзи Дент"
# SITE_PHONE="+7 903 808 01 40"
# OPENROUTER_API_KEY=""
# OPENROUTER_MODEL="qwen/qwen3-vl-30b-a3b-thinking"
